# Copy to `web/.env` and fill in. This is the single source of app config —
# used by `bun run dev` locally AND by docker-compose (env_file: ./web/.env).
# The real `.env` is gitignored; never commit it.

# --- Postgres (the app talks to the DB directly; it lives on the LAN) ---
POSTGRES_HOST=192.168.18.37
POSTGRES_PORT=5432
POSTGRES_DB=mypick-nijigasaku
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# --- Cover CDN (covers resolve to https://<CDN_ENDPOINT>/nijigasaki-album/<slug>.webp) ---
CDN_ENDPOINT=niji-mypick-cdn.naufalalfa.com

# --- Public origin — absolute URLs for share previews (Open Graph) ---
# Defaults to the prod domain if unset; set to your dev/staging origin locally.
SITE_URL=https://mypick-nijigaku.naufalalfa.com

# --- Optional Redis cache ---
# docker-compose injects redis://redis:6379 automatically (see its environment:),
# so leave this unset there. For local `bun run dev`, leave unset to run
# cache-less against the DB, or point at a local Redis.
# REDIS_URL=redis://localhost:6379
